---
layout: layouts/base.njk
---
<div class="about-wrapper">
<div class="about-content">
  {{ content | markdown | safe }}
</div>
</div>

<img class="floating-img" src="{{ floatImage }}" alt="" />

<script>
  const floatingImg = document.querySelector('.floating-img');
  if (floatingImg) {
    let x = Math.random() * (window.innerWidth - 200);
    let y = Math.random() * (window.innerHeight - 200);
    let vx = 0.6;
    let vy = 0.4;
    let angle = 0;
    let rotationSpeed = 0.3;

    if (window.innerWidth > 1200) {
      floatingImg.addEventListener('mouseenter', () => rotationSpeed = 8);
      floatingImg.addEventListener('mouseleave', () => rotationSpeed = 0.3);
    }

    function animateFloat() {
      x += vx;
      y += vy;
      angle += rotationSpeed;
      if (x <= 0 || x >= window.innerWidth - floatingImg.width) vx *= -1;
      if (y <= 0 || y >= window.innerHeight - floatingImg.height) vy *= -1;
      floatingImg.style.left = x + 'px';
      floatingImg.style.top = y + 'px';
      floatingImg.style.transform = `rotate(${angle}deg)`;
      requestAnimationFrame(animateFloat);
    }
    animateFloat();
  }
</script>